rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidActivity(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.questions is list && data.questions.size() >= 1 && data.questions.size() <= 10
          && data.createdAt == request.time
          && data.creatorName is string && data.creatorName.size() <= 60;
    }

    match /activities/{activityId} {
      allow create: if isValidId(activityId) && isValidActivity(incoming());
      allow get: if true;
      allow list: if true;
      allow delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{userId} {
      allow get: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /admins/{adminId} {
      allow read: if true;
    }
  }
}
