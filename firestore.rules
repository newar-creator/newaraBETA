rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidActivity(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.password is string && data.password.size() > 0 && data.password.size() <= 64
          && data.questions is list && data.questions.size() >= 1 && data.questions.size() <= 10
          && data.createdAt == request.time
          && data.creatorName is string && data.creatorName.size() <= 50;
    }

    match /activities/{activityId} {
      allow create: if isValidId(activityId) && isValidActivity(incoming());
      allow get: if true;
      // Note: allow list is intentionally omitted as activities are accessed by specific ID (code)
    }
  }
}
