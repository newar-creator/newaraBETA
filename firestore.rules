rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidActivity(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.questions is list && data.questions.size() >= 1 && data.questions.size() <= 20
          && (data.createdAt == request.time || ('createdAt' in data && data.createdAt == resource.data.createdAt) || !('createdAt' in data))
          && data.creatorName is string && data.creatorName.size() <= 60;
    }

    match /activities/{activityId} {
      allow create: if isValidId(activityId) && isValidActivity(incoming());
      allow get: if true;
      allow list: if true;
      allow update: if isValidId(activityId) && isValidActivity(incoming()) && incoming().creatorName == resource.data.creatorName;
      allow delete: if true; // Enforced by UI moderator check
    }

    function isValidUsername(id) {
      return id is string && id.size() >= 2 && id.size() <= 64;
    }

    match /users/{userId} {
      allow get: if true;
      allow create: if isValidUsername(userId) && incoming().password is string && incoming().password.size() >= 4 && incoming().createdAt == request.time;
      // Allow updates. For AraTester/NewAra we exempt the existing data check to fix the 1.5MB size error
      allow update: if isValidUsername(userId) 
                     && (userId == 'AraTester' || userId == 'NewAra' || !('password' in existing()) || incoming().password == existing().password);
    }

    match /admins/{adminId} {
      allow read: if true;
    }
  }
}
