{
  "entities": {
    "ActivityQuestion": {
      "title": "Activity Question",
      "description": "A single question within a shared activity",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["multiple-choice", "true-false", "writing"]
        },
        "question": {
          "type": "string"
        },
        "options": {
          "type": "array"
        },
        "correctAnswer": {
          "type": "string"
        }
      },
      "required": ["type", "question", "correctAnswer"]
    },
    "SharedActivity": {
      "title": "Shared Activity",
      "description": "User generated activity stored in Firestore",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "creatorName": { "type": "string" },
        "creatorAvatar": { "type": "string" },
        "password": { "type": "string" },
        "questions": { "type": "array" },
        "likes": { "type": "array" },
        "views": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "creatorName", "password", "questions", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile with custom password authentication",
      "type": "object",
      "properties": {
        "password": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "joinedClasses": { "type": "array" },
        "stats": {
          "type": "object",
          "properties": {
            "totalViews": { "type": "number" },
            "totalLikes": { "type": "number" },
            "totalCorrect": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["password", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "User reports for moderation",
      "type": "object",
      "properties": {
        "targetId": { "type": "string" },
        "targetName": { "type": "string" },
        "targetType": { "type": "string", "enum": ["activity", "announcement"] },
        "reporterName": { "type": "string" },
        "creatorName": { "type": "string" },
        "classId": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["targetId", "targetName", "targetType", "reporterName", "reason", "createdAt", "status"]
    },
    "Class": {
      "title": "Classroom",
      "description": "A Google Classroom like class",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "code": { "type": "string" },
        "ownerName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isArchived": { "type": "boolean" },
        "themeColor": { "type": "string" }
      },
      "required": ["name", "code", "ownerName", "createdAt", "isArchived"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "A post within a class",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "attachment": { 
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "type": { "type": "string" },
            "url": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "isDraft": { "type": "boolean" },
        "commentsCount": { "type": "number" }
      },
      "required": ["classId", "authorName", "content", "createdAt", "isDraft"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on an announcement",
      "type": "object",
      "properties": {
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorName", "content", "createdAt"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "A task created by a teacher",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "attachment": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "type": { "type": "string" },
            "url": { "type": "string" }
          }
        }
      },
      "required": ["classId", "title", "createdAt"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A student's work for an assignment",
      "type": "object",
      "properties": {
        "assignmentId": { "type": "string" },
        "studentName": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "attachment": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "type": { "type": "string" },
            "url": { "type": "string" }
          }
        },
        "grade": { "type": "number" },
        "feedback": { "type": "string" }
      },
      "required": ["assignmentId", "studentName", "submittedAt", "attachment"]
    },
    "ResourceCode": {
      "title": "Resource Code",
      "description": "An activity code shared by the teacher",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "title": { "type": "string" },
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["classId", "title", "code", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["assignment", "announcement", "moderation", "update"] },
        "link": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "isRead", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the class chat",
      "type": "object",
      "properties": {
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorName", "content", "createdAt"]
    },
    "GameSession": {
      "title": "Game Session",
      "description": "A multiplayer game server session",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "hostName": { "type": "string" },
        "activityId": { "type": "string" },
        "activity": { "type": "object" },
        "status": { "type": "string", "enum": ["waiting", "playing", "results", "ended"] },
        "currentQuestionIndex": { "type": "number" },
        "timer": { "type": "number" },
        "questionStartTime": { "type": "string", "format": "date-time" },
        "lastActivityAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "hostName", "status", "lastActivityAt", "createdAt"]
    },
    "GamePlayer": {
      "title": "Game Player",
      "description": "A player in a game session",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "score": { "type": "number" },
        "lastResponse": { "type": "object" },
        "isCorrect": { "type": "boolean" },
        "pointsLastRound": { "type": "number" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "score", "joinedAt"]
    },
    "SubjectConfig": {
      "title": "Subject Config",
      "description": "Custom configuration for a subject, like unit order",
      "type": "object",
      "properties": {
        "unitOrder": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/subject_configs/{subjectId}": {
      "schema": "SubjectConfig",
      "description": "Configuration for subjects (e.g. unit order)"
    },
    "/gameSessions/{sessionId}": {
      "schema": "GameSession",
      "description": "Live game servers"
    },
    "/gameSessions/{sessionId}/players/{playerName}": {
      "schema": "GamePlayer",
      "description": "Players in a game"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/activities/{activityId}": {
      "schema": "SharedActivity",
      "description": "Store for shared activities"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Collection of reports against activities."
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Classrooms"
    },
    "/classes/{classId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Group chat messages for the class"
    },
    "/classes/{classId}/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Posts and announcements in a class"
    },
    "/classes/{classId}/announcements/{announcementId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on an announcement"
    },
    "/classes/{classId}/members/{userId}": {
      "schema": "object",
      "description": "Users joined in a class"
    },
    "/classes/{classId}/resources/{resourceId}": {
      "schema": "ResourceCode",
      "description": "Activity codes shared in a class"
    },
    "/classes/{classId}/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Tasks created by teachers"
    },
    "/classes/{classId}/assignments/{assignmentId}/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Task submissions by students"
    }
  }
}
