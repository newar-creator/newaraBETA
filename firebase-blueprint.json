{
  "entities": {
    "ActivityQuestion": {
      "title": "Activity Question",
      "description": "A single question within a shared activity",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["multiple-choice", "true-false", "writing"]
        },
        "question": {
          "type": "string"
        },
        "options": {
          "type": "array"
        },
        "correctAnswer": {
          "type": "string"
        }
      },
      "required": ["type", "question", "correctAnswer"]
    },
    "SharedActivity": {
      "title": "Shared Activity",
      "description": "User generated activity stored in Firestore",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "creatorName": { "type": "string" },
        "creatorAvatar": { "type": "string" },
        "password": { "type": "string" },
        "questions": { "type": "array" },
        "likes": { "type": "array" },
        "views": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "creatorName", "password", "questions", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile with custom password authentication",
      "type": "object",
      "properties": {
        "password": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "totalViews": { "type": "number" },
            "totalLikes": { "type": "number" },
            "totalCorrect": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["password", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "A user report against an activity.",
      "type": "object",
      "properties": {
        "activityId": { "type": "string" },
        "activityName": { "type": "string" },
        "reporterName": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["activityId", "activityName", "reporterName", "reason", "createdAt", "status"]
    }
  },
  "firestore": {
    "/activities/{activityId}": {
      "schema": "SharedActivity",
      "description": "Store for shared activities"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Collection of reports against activities."
    }
  }
}
