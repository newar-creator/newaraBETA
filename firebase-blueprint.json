{
  "entities": {
    "ActivityQuestion": {
      "title": "Activity Question",
      "description": "A single question within a shared activity",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["multiple-choice", "true-false", "writing"]
        },
        "question": {
          "type": "string"
        },
        "options": {
          "type": "array"
        },
        "correctAnswer": {
          "type": "string"
        }
      },
      "required": ["type", "question", "correctAnswer"]
    },
    "SharedActivity": {
      "title": "Shared Activity",
      "description": "User generated activity stored in Firestore",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "creatorName": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "questions": {
          "type": "array"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "creatorName", "password", "questions", "createdAt"]
    }
  },
  "firestore": {
    "/activities/{activityId}": {
      "schema": "SharedActivity",
      "description": "Store for shared activities"
    }
  }
}
